# ====================================
# Редиректы для goruslugimsk.ru
# ====================================

# Статические файлы — отдаём напрямую (ПЕРЕД SPA fallback!)
/robots.txt          /robots.txt          200
/sitemap.xml         /sitemap.xml         200
/favicon.ico         /favicon.ico         200
/og-image.jpg        /og-image.jpg        200
/.well-known/*       /.well-known/:splat  200

# 410 Gone — старые WordPress URL навсегда удалены
# Яндекс/Google быстро деиндексируют страницы с 410
/2022/*              /410.html   410
/wp-admin/*          /410.html   410
/wp-content/*        /410.html   410
/wp-includes/*       /410.html   410
/wp-login.php        /410.html   410
/xmlrpc.php          /410.html   410
/feed/*              /410.html   410

# 404 — попытки взлома (WordPress paths)
/wp-json/*           /404.html   404
/wp-cron.php         /404.html   404

# 301 Redirects — typo transliterations (dezinsekTSiya → dezinsekCiya)
/uslugi/dezinsektsiya/           /uslugi/dezinsekciya/           301
/uslugi/dezinsektsiya/*          /uslugi/dezinsekciya/:splat     301
/uslugi/dezinfektsiya/           /uslugi/dezinfekciya/           301
/uslugi/dezinfektsiya/*          /uslugi/dezinfekciya/:splat     301
/uslugi/deratizatsiya/           /uslugi/deratizaciya/           301
/uslugi/deratizatsiya/*          /uslugi/deratizaciya/:splat     301

# 301 Redirects — combo pages cannibalize pest clusters (Issue #5)
/uslugi/dezinsekciya/klopov-i-tarakanov/*  /uslugi/dezinsekciya/unichtozhenie-klopov/  301
/uslugi/dezinsekciya/klopov-i-bloh/*       /uslugi/dezinsekciya/unichtozhenie-klopov/  301

# 301 Redirects — Anti-cannibalization: Object+Geo leaks
/uslugi/dezinsekciya/ofisov/:slug    /uslugi/dezinsekciya/ofisov/   301
/uslugi/dezinfekciya/ofisov/:slug    /uslugi/dezinfekciya/ofisov/   301
/uslugi/dezinsekciya/hostelov/:slug  /uslugi/dezinsekciya/hostela/  301
/uslugi/dezinfekciya/hostelov/:slug  /uslugi/dezinfekciya/hostela/  301
/uslugi/kroty                        /uslugi/deratizaciya/kroty/    301
/uslugi/kroty/*                      /uslugi/deratizaciya/kroty/    301
/uslugi/borba-s-krotami/kroty        /uslugi/deratizaciya/kroty/    301
/uslugi/borba-s-krotami/kroty/*      /uslugi/deratizaciya/kroty/    301

# 301 Redirects — old geo URLs → new /rajony/ hubs

# 301 Redirects — renamed blog articles (commercial → informational)
/blog/ceny-na-unichtozhenie-tarakany  /blog/skolko-stoit-obrabotka-tarakany/  301
/blog/ceny-na-unichtozhenie-klopy     /blog/skolko-stoit-obrabotka-klopy/     301
/blog/ceny-na-unichtozhenie-muravyi   /blog/skolko-stoit-obrabotka-muravyi/   301
/blog/ceny-na-unichtozhenie-blohi     /blog/skolko-stoit-obrabotka-blohi/     301
/blog/ceny-na-unichtozhenie-mol       /blog/skolko-stoit-obrabotka-mol/       301

# SPA Fallback только для админки (закрыта от индексации)
/admin/*             /index.html  200

# 404 по умолчанию — все неизвестные URL
# Вся публичная часть должна быть пререндерена в статический HTML
/*                   /index.html  200
